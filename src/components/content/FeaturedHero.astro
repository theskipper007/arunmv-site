---
import CategoryPill from "./CategoryPill.astro";
import { formatDate, readingMinutes, type Post } from "../../lib/collections";

interface Props {
  post: Post;
}
const { post } = Astro.props;
const { title, description, pubDate, category } = post.data;
const minutes = readingMinutes(post);
---

<a
  href={`/blog/${post.id}`}
  class="reveal group block rounded-[var(--radius-lg)] border border-border bg-surface p-8 no-underline transition-colors hover:border-accent/40 sm:p-10"
>
  <div class="flex items-center gap-3">
    <CategoryPill category={category} size="sm" />
    <span class="font-mono text-xs text-faint">Featured</span>
  </div>
  <h2
    class="mt-4 max-w-3xl text-3xl font-bold tracking-tight text-ink transition-colors group-hover:text-accent sm:text-4xl"
  >
    {title}
  </h2>
  <p class="mt-3 max-w-2xl text-lg text-muted">{description}</p>
  <p class="mt-5 font-mono text-xs text-faint">
    <time datetime={pubDate.toISOString()}>{formatDate(pubDate)}</time> · {minutes} min read
  </p>
</a>
