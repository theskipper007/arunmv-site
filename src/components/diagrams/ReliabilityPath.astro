---
import Diagram from "../mdx/Diagram.astro";
---

<Diagram
  caption="The model is one box on the request path. Bounded retries, a deterministic fallback, and a circuit breaker are what keep one slow provider from taking down the whole request."
>
  <svg viewBox="0 0 760 188" role="img" aria-label="A request flows into a guarded path: bounded retries with backoff wrap the LLM call, a circuit breaker trips on a slow provider, and a deterministic fallback returns a safe answer. Every call is logged with prompt, model, latency, tokens, and outcome.">
    <defs>
      <marker id="rel-arrow" viewBox="0 0 10 10" refX="8.5" refY="5" markerWidth="7" markerHeight="7" orient="auto-start-reverse">
        <path d="M0,0 L10,5 L0,10 z" fill="var(--color-faint)"></path>
      </marker>
    </defs>

    <!-- Request -->
    <rect x="14" y="40" width="104" height="50" rx="10" fill="var(--color-paper)" stroke="var(--color-border)"></rect>
    <text x="66" y="70" text-anchor="middle" font-family="var(--font-sans)" font-size="13" font-weight="600" fill="var(--color-ink)">Request</text>

    <!-- Guarded zone -->
    <rect x="146" y="20" width="402" height="90" rx="12" fill="color-mix(in oklab, var(--color-accent) 5%, var(--color-surface))" stroke="var(--color-accent)" stroke-dasharray="5 4"></rect>
    <text x="347" y="36" text-anchor="middle" font-family="var(--font-mono)" font-size="9.5" fill="var(--color-accent)">retries · backoff · circuit breaker</text>

    <!-- LLM call -->
    <rect x="168" y="46" width="150" height="48" rx="10" fill="var(--color-paper)" stroke="var(--color-border)"></rect>
    <text x="243" y="68" text-anchor="middle" font-family="var(--font-sans)" font-size="12.5" font-weight="600" fill="var(--color-ink)">LLM call</text>
    <text x="243" y="84" text-anchor="middle" font-family="var(--font-mono)" font-size="9" fill="var(--color-faint)">rate-limit · timeout · bad JSON</text>

    <!-- Fallback -->
    <rect x="372" y="46" width="154" height="48" rx="10" fill="color-mix(in oklab, #2E8B57 8%, var(--color-surface))" stroke="#2E8B57"></rect>
    <text x="449" y="68" text-anchor="middle" font-family="var(--font-sans)" font-size="12.5" font-weight="600" fill="var(--color-ink)">Deterministic</text>
    <text x="449" y="84" text-anchor="middle" font-family="var(--font-mono)" font-size="9" fill="var(--color-faint)">fallback on failure</text>

    <!-- Response -->
    <rect x="576" y="40" width="170" height="50" rx="10" fill="var(--color-paper)" stroke="var(--color-border)"></rect>
    <text x="661" y="70" text-anchor="middle" font-family="var(--font-sans)" font-size="13" font-weight="600" fill="var(--color-ink)">Response</text>

    <!-- arrows -->
    <line x1="118" y1="65" x2="166" y2="65" stroke="var(--color-faint)" stroke-width="1.5" marker-end="url(#rel-arrow)"></line>
    <line x1="318" y1="70" x2="370" y2="70" stroke="var(--color-faint)" stroke-width="1.5" marker-end="url(#rel-arrow)"></line>
    <line x1="548" y1="65" x2="574" y2="65" stroke="var(--color-faint)" stroke-width="1.5" marker-end="url(#rel-arrow)"></line>

    <!-- Observability bar -->
    <rect x="146" y="128" width="600" height="40" rx="8" fill="var(--color-paper)" stroke="var(--color-border)"></rect>
    <text x="446" y="146" text-anchor="middle" font-family="var(--font-sans)" font-size="11.5" font-weight="600" fill="var(--color-ink)">Observability</text>
    <text x="446" y="161" text-anchor="middle" font-family="var(--font-mono)" font-size="9" fill="var(--color-faint)">log prompt · model · latency · tokens · outcome — every call</text>
    <path d="M347,110 L347,126" fill="none" stroke="var(--color-faint)" stroke-width="1.2" stroke-dasharray="3 3" marker-end="url(#rel-arrow)"></path>
  </svg>
</Diagram>
