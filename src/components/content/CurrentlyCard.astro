---
// "Currently" card — quiet trust signals for the hero's right column.
// Edit the rows below to keep them current; everything here is hand-maintained.
interface Props {
  class?: string;
  style?: string;
}
const { class: className = "", style } = Astro.props;

const rows = [
  { label: "Building", value: "Agentic AI products & developer tools" },
  { label: "Focus", value: "RAG · Knowledge graphs · LLM evals" },
  { label: "Stack", value: "TypeScript · React · Python · AWS" },
  { label: "Writing", value: "Knowledge graphs for LLMs" },
];
---

<aside
  class:list={[
    "rounded-[var(--radius-lg)] border border-border bg-surface p-6 shadow-[0_1px_0_rgb(0_0_0/0.02)]",
    className,
  ]}
  style={style}
>
  <div class="flex items-center gap-2 font-mono text-xs text-muted">
    <span class="relative flex h-2 w-2" aria-hidden="true">
      <span
        class="status-ping absolute inline-flex h-full w-full rounded-full bg-emerald-500/60"
      ></span>
      <span class="relative inline-flex h-2 w-2 rounded-full bg-emerald-500"></span>
    </span>
    Open to interesting problems
  </div>

  <p class="mt-5 font-mono text-xs uppercase tracking-widest text-faint">Currently</p>

  <dl class="mt-3 space-y-2.5 text-sm">
    {
      rows.map((row) => (
        <div class="flex gap-3">
          <dt class="w-[4.5rem] shrink-0 font-mono text-xs leading-6 text-faint">{row.label}</dt>
          <dd class="text-ink">{row.value}</dd>
        </div>
      ))
    }
  </dl>
</aside>

<style>
  /* One quiet looping signal — the "I'm here" pulse. Honors reduced-motion. */
  @media (prefers-reduced-motion: no-preference) {
    .status-ping {
      animation: statusPing 2.4s var(--ease) infinite;
    }
    @keyframes statusPing {
      0% {
        transform: scale(1);
        opacity: 0.6;
      }
      75%,
      100% {
        transform: scale(2.2);
        opacity: 0;
      }
    }
  }
</style>
