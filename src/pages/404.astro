---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Not found" description="That page doesn't exist." noindex>
  <section
    class="mx-auto flex min-h-[50vh] flex-col items-center justify-center px-6 text-center"
    style="max-width: var(--content-max);"
  >
    <p class="font-mono text-6xl font-bold text-accent">404</p>
    <h1 class="mt-4 text-2xl font-semibold text-ink">This page wandered off.</h1>
    <p class="mt-2 text-muted">The link may be broken, or the page may have moved.</p>
    <div class="mt-8 flex gap-3">
      <a
        href="/"
        class="rounded-[var(--radius-md)] bg-accent px-4 py-2.5 text-sm font-medium text-white no-underline hover:bg-[var(--color-accent-hover)]"
      >
        Go home
      </a>
      <a
        href="/blog"
        class="rounded-[var(--radius-md)] border border-border px-4 py-2.5 text-sm no-underline hover:border-accent hover:text-accent"
      >
        Browse the blog
      </a>
    </div>
  </section>
</BaseLayout>
