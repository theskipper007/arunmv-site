---
import type { GetStaticPaths, Page } from "astro";
import BaseLayout from "../../../layouts/BaseLayout.astro";
import CategoryNav from "../../../components/content/CategoryNav.astro";
import PostCard from "../../../components/content/PostCard.astro";
import Pagination from "../../../components/content/Pagination.astro";
import { getPublishedPosts, type Post } from "../../../lib/collections";

export const getStaticPaths: GetStaticPaths = async ({ paginate }) => {
  const posts = await getPublishedPosts();
  const listed = posts.filter((p) => !p.data.featured);
  // Page 1 lives at /blog; only emit /blog/page/2..N here.
  return paginate(listed, { pageSize: 12 }).filter(
    (p) => p.params.page !== undefined && p.params.page !== "1",
  );
};

interface Props {
  page: Page<Post>;
}
const { page } = Astro.props;
---

<BaseLayout title={`Blog — page ${page.currentPage}`} description="More writing.">
  <div class="mx-auto px-6 py-16" style="max-width: var(--content-max);">
    <header class="reveal">
      <h1 class="text-3xl font-bold tracking-tight text-ink sm:text-4xl">Writing</h1>
      <p class="mt-3 font-mono text-sm text-faint">Page {page.currentPage} of {page.lastPage}</p>
    </header>

    <div class="mt-10">
      <CategoryNav active="all" />
    </div>

    <div class="mt-2">
      {page.data.map((post) => <PostCard post={post} />)}
    </div>

    <Pagination currentPage={page.currentPage} lastPage={page.lastPage} base="/blog" />
  </div>
</BaseLayout>
