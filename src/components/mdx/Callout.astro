---
import {
  Info,
  Lightbulb,
  TriangleAlert,
  CircleAlert,
  CircleCheck,
  Ban,
  BookOpen,
  Terminal,
} from "@lucide/astro";

interface Props {
  type?: "note" | "tip" | "do" | "dont" | "warning" | "danger" | "reference" | "output";
  title?: string;
}

const { type = "note", title } = Astro.props;

const config = {
  note: { Icon: Info, label: "Note", accent: "var(--color-accent)", mono: false },
  tip: { Icon: Lightbulb, label: "Tip", accent: "#2E8B57", mono: false },
  do: { Icon: CircleCheck, label: "Do this", accent: "#2E8B57", mono: false },
  dont: { Icon: Ban, label: "Don't", accent: "#C2402F", mono: false },
  warning: { Icon: TriangleAlert, label: "Warning", accent: "#C9821B", mono: false },
  danger: { Icon: CircleAlert, label: "Heads up", accent: "#C2402F", mono: false },
  reference: { Icon: BookOpen, label: "Reference", accent: "#3B6EA5", mono: false },
  output: { Icon: Terminal, label: "Output", accent: "#6B7280", mono: true },
} as const;

const { Icon, label, accent, mono } = config[type];
---

<aside
  class="my-6 rounded-[var(--radius-md)] border border-border p-4"
  style={`border-left: 3px solid ${accent}; background: color-mix(in oklab, ${accent} 5%, var(--color-surface));`}
  role="note"
>
  <p class="m-0 flex items-center gap-2 font-sans text-sm font-semibold text-ink">
    <Icon size={16} stroke-width={1.5} style={`color:${accent}`} />
    {title ?? label}
  </p>
  <div
    class:list={[
      "callout-body mt-2 leading-relaxed text-muted",
      mono ? "font-mono text-[0.82rem]" : "text-[0.95rem]",
    ]}
  >
    <slot />
  </div>
</aside>
