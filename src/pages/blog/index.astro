---
import BaseLayout from "../../layouts/BaseLayout.astro";
import CategoryNav from "../../components/content/CategoryNav.astro";
import FeaturedHero from "../../components/content/FeaturedHero.astro";
import PostCard from "../../components/content/PostCard.astro";
import Pagination from "../../components/content/Pagination.astro";
import { getPublishedPosts } from "../../lib/collections";

const PAGE_SIZE = 12;
const posts = await getPublishedPosts();
const featured = posts.find((p) => p.data.featured) ?? null;
const listed = posts.filter((p) => !p.data.featured);
const pageItems = listed.slice(0, PAGE_SIZE);
const lastPage = Math.max(1, Math.ceil(listed.length / PAGE_SIZE));
---

<BaseLayout
  title="Blog"
  description="Writing on AI engineering, tech opinions, sports, and the occasional tangent."
>
  <div class="mx-auto px-6 py-16" style="max-width: var(--content-max);">
    <header class="reveal">
      <h1 class="text-3xl font-bold tracking-tight text-ink sm:text-4xl">Writing</h1>
      <p class="mt-3 max-w-2xl text-muted">
        Notes on building practical AI systems — plus tech opinions and a clearly separated
        personal stream.
      </p>
    </header>

    {
      featured && (
        <div class="mt-10">
          <FeaturedHero post={featured} />
        </div>
      )
    }

    <div class="mt-10">
      <CategoryNav active="all" />
    </div>

    <div
      class="mt-6 grid gap-5"
      style="grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));"
    >
      {pageItems.map((post) => <PostCard post={post} />)}
      {pageItems.length === 0 && <p class="py-16 text-faint">No posts yet.</p>}
    </div>

    <Pagination currentPage={1} lastPage={lastPage} base="/blog" />
  </div>
</BaseLayout>
