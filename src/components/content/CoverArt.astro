---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";
import { CATEGORY_THEME, categoryLabel, type Category } from "../../lib/collections";

interface Props {
  category: Category;
  image?: ImageMetadata;
  video?: string;
  alt?: string;
  /** CSS aspect-ratio value, e.g. "16 / 9". */
  ratio?: string;
  /** Show the topic label over the animated fallback. */
  label?: boolean;
  class?: string;
}

const {
  category,
  image,
  video,
  alt = "",
  ratio = "16 / 9",
  label = true,
  class: className = "",
} = Astro.props;

const t = CATEGORY_THEME[category];
const style = `--c1:${t.c1};--c2:${t.c2};--c3:${t.c3};aspect-ratio:${ratio};`;
const kind = video ? "video" : image ? "image" : "motion";
---

<div class:list={["cover-art", className]} style={style} data-kind={kind}>
  {
    video ? (
      <video
        class="cover-media"
        autoplay
        muted
        loop
        playsinline
        preload="metadata"
        aria-label={alt}
      >
        <source src={video} />
      </video>
    ) : image ? (
      <Image
        src={image}
        alt={alt}
        widths={[400, 800, 1200]}
        sizes="(max-width: 768px) 100vw, 800px"
        class="cover-media"
      />
    ) : (
      <div class="cover-motion" aria-hidden="true">
        <span class="cover-blob cover-blob-1" />
        <span class="cover-blob cover-blob-2" />
        <span class="cover-blob cover-blob-3" />
        {label && <span class="cover-label">{categoryLabel(category)}</span>}
      </div>
    )
  }
</div>
