---
import type { GetStaticPaths } from "astro";
import BaseLayout from "../../../layouts/BaseLayout.astro";
import PostCard from "../../../components/content/PostCard.astro";
import { getPublishedPosts, allTags, postsByTag } from "../../../lib/collections";

export const getStaticPaths: GetStaticPaths = async () => {
  const posts = await getPublishedPosts();
  return allTags(posts).map(({ tag }) => ({
    params: { tag },
    props: { posts: postsByTag(posts, tag), tag },
  }));
};

interface Props {
  posts: Awaited<ReturnType<typeof getPublishedPosts>>;
  tag: string;
}
const { posts, tag } = Astro.props;
---

<BaseLayout title={`#${tag} — Blog`} description={`Posts tagged ${tag}.`}>
  <div class="mx-auto px-6 py-16" style="max-width: var(--content-max);">
    <header class="reveal">
      <p class="font-mono text-sm text-faint">Tag</p>
      <h1 class="mt-1 font-mono text-3xl font-bold tracking-tight text-ink sm:text-4xl">
        #{tag}
      </h1>
      <p class="mt-3 font-mono text-sm text-faint">
        {posts.length} post{posts.length === 1 ? "" : "s"}
      </p>
    </header>

    <div
      class="mt-10 grid gap-5"
      style="grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));"
    >
      {posts.map((post) => <PostCard post={post} />)}
    </div>
  </div>
</BaseLayout>
