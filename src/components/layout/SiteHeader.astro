---
import { Search } from "@lucide/astro";
import { NAV } from "../../lib/seo";
import ThemeToggle from "../ui/ThemeToggle.tsx";
import CommandPalette from "../ui/CommandPalette.tsx";
import MobileNav from "../ui/MobileNav.tsx";

const pathname = Astro.url.pathname;
const isActive = (href: string) => pathname === href || pathname.startsWith(href + "/");
---

<header class="sticky top-0 z-40 border-b border-border bg-paper/80 backdrop-blur">
  <div
    class="mx-auto flex h-16 items-center justify-between gap-4 px-6"
    style="max-width: var(--content-max);"
  >
    <a
      href="/"
      class="font-mono text-sm font-medium text-ink no-underline transition-colors hover:text-accent"
    >
      arun&nbsp;mv
    </a>

    <nav aria-label="Primary" class="hidden items-center gap-1 md:flex">
      {
        NAV.map((item) => (
          <a
            href={item.href}
            aria-current={isActive(item.href) ? "page" : undefined}
            class:list={[
              "rounded-[var(--radius-md)] px-3 py-2 text-sm no-underline transition-colors hover:text-ink",
              isActive(item.href) ? "text-ink" : "text-muted",
            ]}
          >
            {item.label}
          </a>
        ))
      }
    </nav>

    <div class="flex items-center gap-1">
      <button
        type="button"
        data-open-command-palette
        aria-label="Search (Ctrl K)"
        class="inline-flex h-11 items-center gap-2 rounded-[var(--radius-md)] px-3 text-muted transition-colors hover:text-ink"
      >
        <Search size={18} stroke-width={1.5} />
        <kbd
          class="hidden rounded border border-border px-1.5 py-0.5 font-mono text-[0.7rem] text-faint lg:inline"
          >⌘K</kbd
        >
      </button>
      <ThemeToggle client:load />
      <MobileNav client:idle />
    </div>
  </div>
  <CommandPalette client:idle />
</header>
