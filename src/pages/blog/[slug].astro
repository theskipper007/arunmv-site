---
import type { GetStaticPaths } from "astro";
import { render } from "astro:content";
import ArticleLayout from "../../layouts/ArticleLayout.astro";
import Callout from "../../components/mdx/Callout.astro";
import Figure from "../../components/mdx/Figure.astro";
import Diagram from "../../components/mdx/Diagram.astro";
import Tldr from "../../components/mdx/Tldr.astro";
import {
  getPublishedPosts,
  relatedPosts,
  seriesParts,
  type Post,
} from "../../lib/collections";

export const getStaticPaths: GetStaticPaths = async () => {
  const posts = await getPublishedPosts();
  return posts.map((post) => ({ params: { slug: post.id }, props: { post } }));
};

interface Props {
  post: Post;
}
const { post } = Astro.props;
const { Content, headings } = await render(post);

const all = await getPublishedPosts();
const related = relatedPosts(post, all, 3);
const series = post.data.series
  ? { name: post.data.series.name, parts: seriesParts(all, post.data.series.name) }
  : undefined;
---

<ArticleLayout post={post} headings={headings} related={related} series={series}>
  <Content components={{ Callout, Figure, Diagram, Tldr }} />
</ArticleLayout>
