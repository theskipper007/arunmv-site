---
import Diagram from "../mdx/Diagram.astro";
---

<Diagram
  caption="Retrieval runs four prongs in parallel and fuses them. The symbol-name prong — trigram matching over real identifiers — is what lets a half-remembered name find the function."
>
  <svg viewBox="0 0 760 214" role="img" aria-label="A query fans out into four retrieval prongs — dense semantic, lexical, file-path, and symbol-name — which fuse, then re-rank, into the final context. The symbol-name prong is highlighted as the one that mattered most.">
    <defs>
      <marker id="mpr-arrow" viewBox="0 0 10 10" refX="8.5" refY="5" markerWidth="7" markerHeight="7" orient="auto-start-reverse">
        <path d="M0,0 L10,5 L0,10 z" fill="var(--color-faint)"></path>
      </marker>
    </defs>

    <!-- Query -->
    <rect x="14" y="79" width="96" height="56" rx="10" fill="var(--color-paper)" stroke="var(--color-border)"></rect>
    <text x="62" y="103" text-anchor="middle" font-family="var(--font-sans)" font-size="14" font-weight="600" fill="var(--color-ink)">Query</text>
    <text x="62" y="120" text-anchor="middle" font-family="var(--font-mono)" font-size="9" fill="var(--color-faint)">symbol?</text>

    <!-- Prongs -->
    <g font-family="var(--font-sans)" font-size="12.5" font-weight="600">
      <rect x="180" y="14" width="186" height="34" rx="8" fill="var(--color-paper)" stroke="var(--color-border)"></rect>
      <text x="273" y="35" text-anchor="middle" fill="var(--color-ink)">Dense semantic</text>

      <rect x="180" y="58" width="186" height="34" rx="8" fill="var(--color-paper)" stroke="var(--color-border)"></rect>
      <text x="273" y="79" text-anchor="middle" fill="var(--color-ink)">Lexical (BM25)</text>

      <rect x="180" y="102" width="186" height="34" rx="8" fill="var(--color-paper)" stroke="var(--color-border)"></rect>
      <text x="273" y="123" text-anchor="middle" fill="var(--color-ink)">File-path</text>

      <rect x="180" y="146" width="186" height="34" rx="8" fill="color-mix(in oklab, var(--color-accent) 7%, var(--color-paper))" stroke="var(--color-accent)" stroke-width="2"></rect>
      <text x="273" y="167" text-anchor="middle" fill="var(--color-ink)">Symbol-name (trigram)</text>
    </g>

    <!-- Fuse -->
    <rect x="430" y="79" width="92" height="56" rx="10" fill="var(--color-paper)" stroke="var(--color-border)"></rect>
    <text x="476" y="103" text-anchor="middle" font-family="var(--font-sans)" font-size="13.5" font-weight="600" fill="var(--color-ink)">Fuse</text>
    <text x="476" y="120" text-anchor="middle" font-family="var(--font-mono)" font-size="9" fill="var(--color-faint)">RRF</text>

    <!-- Re-rank -->
    <rect x="554" y="79" width="92" height="56" rx="10" fill="var(--color-paper)" stroke="var(--color-border)"></rect>
    <text x="600" y="111" text-anchor="middle" font-family="var(--font-sans)" font-size="13.5" font-weight="600" fill="var(--color-ink)">Re-rank</text>

    <!-- Context -->
    <rect x="678" y="79" width="68" height="56" rx="10" fill="color-mix(in oklab, #2E8B57 8%, var(--color-paper))" stroke="#2E8B57"></rect>
    <text x="712" y="111" text-anchor="middle" font-family="var(--font-sans)" font-size="12.5" font-weight="600" fill="var(--color-ink)">Context</text>

    <!-- Fan-out: query to each prong -->
    <g stroke="var(--color-faint)" stroke-width="1.4" fill="none">
      <path d="M110,100 C150,100 150,31 178,31" marker-end="url(#mpr-arrow)"></path>
      <path d="M110,103 C150,103 150,75 178,75" marker-end="url(#mpr-arrow)"></path>
      <path d="M110,111 C150,111 150,119 178,119" marker-end="url(#mpr-arrow)"></path>
      <path d="M110,114 C150,114 150,163 178,163" marker-end="url(#mpr-arrow)"></path>
    </g>
    <!-- Fan-in: each prong to fuse -->
    <g stroke="var(--color-faint)" stroke-width="1.4" fill="none">
      <path d="M366,31 C400,31 400,100 428,100" marker-end="url(#mpr-arrow)"></path>
      <path d="M366,75 C400,75 400,104 428,104" marker-end="url(#mpr-arrow)"></path>
      <path d="M366,119 C400,119 400,110 428,110" marker-end="url(#mpr-arrow)"></path>
      <path d="M366,163 C400,163 400,114 428,114" marker-end="url(#mpr-arrow)"></path>
    </g>
    <!-- Fuse -> Re-rank -> Context -->
    <line x1="522" y1="107" x2="552" y2="107" stroke="var(--color-faint)" stroke-width="1.5" marker-end="url(#mpr-arrow)"></line>
    <line x1="646" y1="107" x2="676" y2="107" stroke="var(--color-faint)" stroke-width="1.5" marker-end="url(#mpr-arrow)"></line>
  </svg>
</Diagram>
