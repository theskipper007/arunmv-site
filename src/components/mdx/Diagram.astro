---
/**
 * Frame + caption wrapper for inline-SVG diagrams. The SVG itself is authored
 * in a dedicated component (or passed as a slot) using `var(--color-*)` tokens
 * so it stays crisp and theme-aware in both light and dark.
 */
interface Props {
  caption?: string;
}
const { caption } = Astro.props;
---

<figure class="diagram my-8">
  <div class="diagram-frame">
    <slot />
  </div>
  {caption && <figcaption>{caption}</figcaption>}
</figure>

<style>
  .diagram-frame {
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    background: var(--color-surface);
    padding: 1.35rem 1.1rem;
    overflow-x: auto;
  }
  .diagram :global(svg) {
    display: block;
    width: 100%;
    height: auto;
    max-width: 100%;
  }
  figcaption {
    margin-top: 0.6rem;
    text-align: center;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    line-height: 1.5;
    color: var(--color-faint);
  }
</style>
