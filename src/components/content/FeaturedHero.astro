---
import CategoryPill from "./CategoryPill.astro";
import CoverArt from "./CoverArt.astro";
import { formatDate, readingMinutes, type Post } from "../../lib/collections";

interface Props {
  post: Post;
}
const { post } = Astro.props;
const { title, description, pubDate, category, heroImage, heroVideo } = post.data;
const minutes = readingMinutes(post);
---

<article
  class="reveal group relative flex flex-col overflow-hidden rounded-[var(--radius-lg)] border border-border bg-surface transition-colors hover:border-accent/40"
>
  <CoverArt
    category={category}
    image={heroImage}
    video={heroVideo}
    alt={title}
    ratio="68 / 37"
    class="cover-art--flush"
  />
  <div class="flex flex-1 flex-col justify-center p-8 sm:p-10">
    <div class="flex items-center gap-3">
      <CategoryPill category={category} size="sm" class="relative z-10" />
      <span class="font-mono text-xs text-faint">Featured</span>
    </div>
    <h2 class="mt-4 text-3xl font-bold tracking-tight sm:text-4xl">
      <a
        href={`/blog/${post.id}`}
        class="text-ink no-underline transition-colors after:absolute after:inset-0 after:content-[''] group-hover:text-accent"
      >
        {title}
      </a>
    </h2>
    <p class="mt-3 text-lg text-muted">{description}</p>
    <p class="mt-5 font-mono text-xs text-faint">
      <time datetime={pubDate.toISOString()}>{formatDate(pubDate)}</time> · {minutes} min read
    </p>
  </div>
</article>
