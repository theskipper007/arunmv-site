---
import BaseLayout from "../../layouts/BaseLayout.astro";
import BuildInProgress from "../../components/content/BuildInProgress.astro";
---

<BaseLayout
  title="Projects"
  description="Project case studies are in the works — coming soon."
>
  <div class="mx-auto px-6 py-16" style="max-width: var(--content-max);">
    <header class="reveal">
      <h1 class="text-3xl font-bold tracking-tight text-ink sm:text-4xl">Projects</h1>
      <p class="mt-3 max-w-2xl text-muted">
        Case studies — Problem · Approach · Stack · Result · Learnings — are on the way.
      </p>
    </header>

    <div class="reveal mt-10">
      <BuildInProgress
        title="Coming soon"
        message="I'm writing up the case studies — graph-grounded LLM features, legacy modernization, and AI at scale. Check back shortly."
      />
    </div>
  </div>
</BaseLayout>
