---
import Diagram from "../mdx/Diagram.astro";
---

<Diagram
  caption="Vector-only RAG returns the top-k nearest chunks — each relevant in isolation, with no links between them, so the model guesses the connective tissue. A graph seeds from the same semantic match, then traverses typed edges to return a connected neighbourhood the model can actually reason over."
>
  <svg viewBox="0 0 760 244" role="img" aria-label="Left: vector-only retrieval returns four disconnected chunks ranked by similarity, with the model forced to guess how they connect. Right: graph retrieval seeds from a semantic match then expands along typed edges like DEPENDS_ON and CAUSED_BY, returning a connected subgraph.">
    <defs>
      <marker id="vg-arrow" viewBox="0 0 10 10" refX="8.5" refY="5" markerWidth="7" markerHeight="7" orient="auto-start-reverse">
        <path d="M0,0 L10,5 L0,10 z" fill="var(--color-faint)"></path>
      </marker>
    </defs>

    <!-- LEFT: vector-only -->
    <text x="30" y="22" font-family="var(--font-sans)" font-size="12.5" font-weight="700" fill="var(--color-ink)">Vector-only</text>
    <text x="30" y="37" font-family="var(--font-mono)" font-size="9" fill="var(--color-faint)">top-k by similarity — disconnected</text>

    <rect x="30" y="52" width="120" height="34" rx="6" fill="var(--color-paper)" stroke="var(--color-border)"></rect>
    <text x="90" y="73" text-anchor="middle" font-family="var(--font-mono)" font-size="10" fill="var(--color-muted)">chunk · 0.91</text>
    <rect x="180" y="52" width="120" height="34" rx="6" fill="var(--color-paper)" stroke="var(--color-border)"></rect>
    <text x="240" y="73" text-anchor="middle" font-family="var(--font-mono)" font-size="10" fill="var(--color-muted)">chunk · 0.88</text>
    <rect x="30" y="104" width="120" height="34" rx="6" fill="var(--color-paper)" stroke="var(--color-border)"></rect>
    <text x="90" y="125" text-anchor="middle" font-family="var(--font-mono)" font-size="10" fill="var(--color-muted)">chunk · 0.86</text>
    <rect x="180" y="104" width="120" height="34" rx="6" fill="var(--color-paper)" stroke="var(--color-border)"></rect>
    <text x="240" y="125" text-anchor="middle" font-family="var(--font-mono)" font-size="10" fill="var(--color-muted)">chunk · 0.84</text>

    <text x="165" y="172" text-anchor="middle" font-family="var(--font-sans)" font-size="11" font-style="italic" fill="#C2402F">no edges — model guesses</text>
    <text x="165" y="188" text-anchor="middle" font-family="var(--font-sans)" font-size="11" font-style="italic" fill="#C2402F">the connective tissue</text>

    <!-- divider -->
    <line x1="380" y1="20" x2="380" y2="224" stroke="var(--color-border)" stroke-width="1" stroke-dasharray="4 4"></line>

    <!-- RIGHT: graph -->
    <text x="410" y="22" font-family="var(--font-sans)" font-size="12.5" font-weight="700" fill="var(--color-ink)">Knowledge graph</text>
    <text x="410" y="37" font-family="var(--font-mono)" font-size="9" fill="var(--color-faint)">seed by similarity, expand by structure</text>

    <!-- nodes -->
    <circle cx="470" cy="92" r="26" fill="color-mix(in oklab, var(--color-accent) 14%, var(--color-surface))" stroke="var(--color-accent)"></circle>
    <text x="470" y="96" text-anchor="middle" font-family="var(--font-sans)" font-size="10.5" font-weight="600" fill="var(--color-ink)">seed</text>

    <circle cx="610" cy="62" r="24" fill="var(--color-paper)" stroke="var(--color-border)"></circle>
    <text x="610" y="66" text-anchor="middle" font-family="var(--font-sans)" font-size="10" fill="var(--color-ink)">service</text>

    <circle cx="660" cy="148" r="24" fill="var(--color-paper)" stroke="var(--color-border)"></circle>
    <text x="660" y="152" text-anchor="middle" font-family="var(--font-sans)" font-size="10" fill="var(--color-ink)">cause</text>

    <circle cx="500" cy="186" r="24" fill="var(--color-paper)" stroke="var(--color-border)"></circle>
    <text x="500" y="190" text-anchor="middle" font-family="var(--font-sans)" font-size="10" fill="var(--color-ink)">module</text>

    <!-- edges -->
    <line x1="495" y1="82" x2="586" y2="66" stroke="var(--color-faint)" stroke-width="1.4" marker-end="url(#vg-arrow)"></line>
    <text x="540" y="64" text-anchor="middle" font-family="var(--font-mono)" font-size="8" fill="#2E8B57">DEPENDS_ON</text>
    <line x1="494" y1="106" x2="638" y2="142" stroke="var(--color-faint)" stroke-width="1.4" marker-end="url(#vg-arrow)"></line>
    <text x="586" y="118" text-anchor="middle" font-family="var(--font-mono)" font-size="8" fill="#2E8B57">CAUSED_BY</text>
    <line x1="478" y1="117" x2="496" y2="162" stroke="var(--color-faint)" stroke-width="1.4" marker-end="url(#vg-arrow)"></line>
    <text x="455" y="146" text-anchor="middle" font-family="var(--font-mono)" font-size="8" fill="#2E8B57">PART_OF</text>

    <text x="555" y="220" text-anchor="middle" font-family="var(--font-sans)" font-size="11" font-style="italic" fill="#2E8B57">a connected neighbourhood to reason over</text>
  </svg>
</Diagram>
