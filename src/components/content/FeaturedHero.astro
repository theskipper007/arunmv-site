---
import CategoryPill from "./CategoryPill.astro";
import CoverArt from "./CoverArt.astro";
import { formatDate, readingMinutes, type Post } from "../../lib/collections";

interface Props {
  post: Post;
}
const { post } = Astro.props;
const { title, description, pubDate, category, heroImage, heroVideo } = post.data;
const minutes = readingMinutes(post);
---

<a
  href={`/blog/${post.id}`}
  class="reveal group grid items-stretch gap-6 overflow-hidden rounded-[var(--radius-lg)] border border-border bg-surface no-underline transition-colors hover:border-accent/40 md:grid-cols-2"
>
  <CoverArt
    category={category}
    image={heroImage}
    video={heroVideo}
    alt={title}
    ratio="16 / 10"
    class="h-full"
  />
  <div class="flex flex-col justify-center p-8 sm:p-10">
    <div class="flex items-center gap-3">
      <CategoryPill category={category} size="sm" />
      <span class="font-mono text-xs text-faint">Featured</span>
    </div>
    <h2
      class="mt-4 text-3xl font-bold tracking-tight text-ink transition-colors group-hover:text-accent sm:text-4xl"
    >
      {title}
    </h2>
    <p class="mt-3 text-lg text-muted">{description}</p>
    <p class="mt-5 font-mono text-xs text-faint">
      <time datetime={pubDate.toISOString()}>{formatDate(pubDate)}</time> · {minutes} min read
    </p>
  </div>
</a>
