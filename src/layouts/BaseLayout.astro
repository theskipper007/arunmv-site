---
// Self-hosted variable fonts (subset, font-display: swap via Fontsource).
import "@fontsource-variable/inter";
import "@fontsource-variable/newsreader";
import "@fontsource-variable/jetbrains-mono";
import "../styles/global.css";
import { ClientRouter } from "astro:transitions";
import SiteHeader from "../components/layout/SiteHeader.astro";
import Footer from "../components/layout/Footer.astro";
import SEOHead from "../components/seo/SEOHead.astro";
import Analytics from "@vercel/analytics/astro";

interface Props {
  title?: string;
  description?: string;
  image?: string;
  type?: "website" | "article";
  publishedTime?: string;
  modifiedTime?: string;
  schema?: Record<string, unknown>[];
  noindex?: boolean;
}

const props = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    {/* Dark is the site default; keep the browser chrome in step. */}
    <meta name="theme-color" content="#111110" />

    {/* Set theme before paint to avoid a flash (spec §7). Dark is the site
        default; a previously saved choice (light or dark) always wins. Re-applied
        after each View-Transitions swap so navigation never reverts the theme. */}
    <script is:inline>
      (() => {
        const apply = () => {
          const stored = localStorage.getItem("theme");
          document.documentElement.dataset.theme =
            stored === "light" || stored === "dark" ? stored : "dark";
        };
        apply();
        document.addEventListener("astro:after-swap", apply);
      })();
    </script>

    <SEOHead {...props} />
    <ClientRouter />
  </head>
  <body>
    <a
      href="#main"
      class="sr-only rounded-[var(--radius-md)] bg-surface px-4 py-2 focus:not-sr-only focus:absolute focus:left-4 focus:top-4 focus:z-50"
      >Skip to content</a
    >
    <SiteHeader />
    <main id="main">
      <slot />
    </main>
    <Footer />
    <Analytics />

    <script>
      // On-scroll fade-rise; idempotent and View-Transitions-aware (spec §6).
      function initReveal() {
        const els = document.querySelectorAll(".reveal:not(.is-visible)");
        if (!("IntersectionObserver" in window) || els.length === 0) {
          els.forEach((el) => el.classList.add("is-visible"));
          return;
        }
        const io = new IntersectionObserver(
          (entries, obs) => {
            for (const e of entries) {
              if (e.isIntersecting) {
                e.target.classList.add("is-visible");
                obs.unobserve(e.target);
              }
            }
          },
          { rootMargin: "0px 0px -10% 0px" },
        );
        els.forEach((el) => io.observe(el));
      }
      initReveal();
      document.addEventListener("astro:page-load", initReveal);
    </script>
  </body>
</html>
