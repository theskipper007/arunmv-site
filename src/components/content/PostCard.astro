---
import CategoryPill from "./CategoryPill.astro";
import CoverArt from "./CoverArt.astro";
import { formatDate, readingMinutes, type Post } from "../../lib/collections";

interface Props {
  post: Post;
}
const { post } = Astro.props;
const { title, description, pubDate, category, heroImage, heroVideo } = post.data;
const minutes = readingMinutes(post);
---

<article
  class="reveal group flex h-full flex-col overflow-hidden rounded-[var(--radius-lg)] border border-border bg-surface transition-colors hover:border-accent/40"
>
  <a href={`/blog/${post.id}`} class="block no-underline" aria-label={title}>
    <CoverArt
      category={category}
      image={heroImage}
      video={heroVideo}
      alt={title}
      ratio="16 / 9"
    />
  </a>
  <div class="flex flex-1 flex-col gap-3 p-5">
    <div class="flex items-center gap-3">
      <CategoryPill category={category} size="sm" />
      <span class="font-mono text-xs text-faint">
        <time datetime={pubDate.toISOString()}>{formatDate(pubDate)}</time> · {minutes} min
      </span>
    </div>
    <h3 class="text-xl font-semibold tracking-tight">
      <a
        href={`/blog/${post.id}`}
        class="text-ink no-underline transition-colors group-hover:text-accent"
      >
        {title}
      </a>
    </h3>
    <p class="text-muted">{description}</p>
  </div>
</article>
