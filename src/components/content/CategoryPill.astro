---
import { categoryLabel, categoryTheme, type Category } from "../../lib/collections";

interface Props {
  category: Category;
  size?: "sm" | "md";
}
const { category, size = "md" } = Astro.props;
const cls = size === "sm" ? "text-[0.7rem] px-2 py-0.5" : "text-xs px-2.5 py-1";
const tint = categoryTheme(category).tint;
const style = `--pill:${tint};`;
---

<a
  href={`/blog/category/${category}`}
  style={style}
  class:list={[
    "category-pill inline-block rounded-[var(--radius-pill)] border font-mono uppercase tracking-wide no-underline transition-colors",
    cls,
  ]}
>
  {categoryLabel(category)}
</a>
