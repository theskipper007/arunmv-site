---
import Diagram from "../mdx/Diagram.astro";
---

<Diagram
  caption="Scope is resolved from the agent's API key — never from what the model says — and compiled into the same query as the vector search. An agent owning zero repositories fails closed: an empty allow-list that matches nothing."
>
  <svg viewBox="0 0 760 204" role="img" aria-label="Retrieval access control: an agent's API key resolves to a scope, which is compiled into a repo equals ANY clause and run as one query with the vector search. An agent with no repositories fails closed to an empty array that matches nothing.">
    <defs>
      <marker id="scr-arrow" viewBox="0 0 10 10" refX="8.5" refY="5" markerWidth="7" markerHeight="7" orient="auto-start-reverse">
        <path d="M0,0 L10,5 L0,10 z" fill="var(--color-faint)"></path>
      </marker>
    </defs>

    <!-- Agent -->
    <rect x="14" y="28" width="118" height="58" rx="10" fill="var(--color-paper)" stroke="var(--color-border)"></rect>
    <text x="73" y="52" text-anchor="middle" font-family="var(--font-sans)" font-size="13" font-weight="600" fill="var(--color-ink)">Agent</text>
    <text x="73" y="70" text-anchor="middle" font-family="var(--font-mono)" font-size="9.5" fill="var(--color-faint)">API key</text>

    <!-- Resolve scope -->
    <rect x="156" y="28" width="150" height="58" rx="10" fill="color-mix(in oklab, var(--color-accent) 7%, var(--color-paper))" stroke="var(--color-accent)"></rect>
    <text x="231" y="52" text-anchor="middle" font-family="var(--font-sans)" font-size="13" font-weight="600" fill="var(--color-ink)">Resolve scope</text>
    <text x="231" y="70" text-anchor="middle" font-family="var(--font-mono)" font-size="9" fill="var(--color-faint)">from key, not the model</text>

    <!-- Compile SQL -->
    <rect x="330" y="28" width="174" height="58" rx="10" fill="var(--color-paper)" stroke="var(--color-border)"></rect>
    <text x="417" y="52" text-anchor="middle" font-family="var(--font-mono)" font-size="12" font-weight="600" fill="var(--color-ink)">repo = ANY(scope)</text>
    <text x="417" y="70" text-anchor="middle" font-family="var(--font-mono)" font-size="9" fill="var(--color-faint)">compiled into the query</text>

    <!-- One query -->
    <rect x="528" y="28" width="214" height="58" rx="10" fill="color-mix(in oklab, #2E8B57 8%, var(--color-surface))" stroke="#2E8B57"></rect>
    <text x="635" y="52" text-anchor="middle" font-family="var(--font-sans)" font-size="12.5" font-weight="600" fill="var(--color-ink)">Vector + relational</text>
    <text x="635" y="70" text-anchor="middle" font-family="var(--font-mono)" font-size="9" fill="var(--color-faint)">one statement · one DB</text>

    <!-- top-row arrows -->
    <line x1="132" y1="57" x2="154" y2="57" stroke="var(--color-faint)" stroke-width="1.5" marker-end="url(#scr-arrow)"></line>
    <line x1="306" y1="57" x2="328" y2="57" stroke="var(--color-faint)" stroke-width="1.5" marker-end="url(#scr-arrow)"></line>
    <line x1="504" y1="57" x2="526" y2="57" stroke="var(--color-faint)" stroke-width="1.5" marker-end="url(#scr-arrow)"></line>

    <!-- fail-closed branch -->
    <path d="M231,86 L231,128" fill="none" stroke="var(--color-accent)" stroke-width="1.4" stroke-dasharray="4 3" marker-end="url(#scr-arrow)"></path>
    <rect x="120" y="130" width="520" height="52" rx="10" fill="color-mix(in oklab, var(--color-accent) 6%, var(--color-surface))" stroke="var(--color-accent)"></rect>
    <text x="380" y="152" text-anchor="middle" font-family="var(--font-sans)" font-size="12.5" font-weight="600" fill="var(--color-ink)">Fail-closed — zero repositories in scope</text>
    <text x="380" y="170" text-anchor="middle" font-family="var(--font-mono)" font-size="9.5" fill="var(--color-faint)">empty allow-list → ARRAY[]::text[] → matches nothing (never a broad search)</text>
  </svg>
</Diagram>
