---
import { categoryLabel, type Category } from "../../lib/collections";

interface Props {
  category: Category;
  size?: "sm" | "md";
}
const { category, size = "md" } = Astro.props;
const cls = size === "sm" ? "text-[0.7rem] px-2 py-0.5" : "text-xs px-2.5 py-1";
---

<a
  href={`/blog/category/${category}`}
  class:list={[
    "inline-block rounded-[var(--radius-pill)] border border-border font-mono uppercase tracking-wide text-muted no-underline transition-colors hover:border-accent hover:text-accent",
    cls,
  ]}
>
  {categoryLabel(category)}
</a>
