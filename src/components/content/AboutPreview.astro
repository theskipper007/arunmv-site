---
import { ArrowRight } from "@lucide/astro";
---

<section class="mx-auto px-6 py-10" style="max-width: var(--content-max);">
  <div class="reveal">
    <h2 class="font-mono text-xs uppercase tracking-widest text-faint">About</h2>
    <p class="mt-4 max-w-2xl font-serif text-xl leading-relaxed text-ink sm:text-2xl">
      I care about software that's still good a year later. I build AI products, write to think
      clearly, follow football too closely, and optimize for the long game over the quick win.
    </p>
    <a
      href="/about"
      class="mt-5 inline-flex items-center gap-1.5 text-sm font-medium text-accent no-underline transition-colors hover:text-[var(--color-accent-hover)]"
    >
      More about me <ArrowRight size={15} stroke-width={2} />
    </a>
  </div>
</section>
