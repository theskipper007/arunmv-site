---
import { Image } from "astro:assets";
import { Mail } from "@lucide/astro";
import GithubIcon from "../components/ui/icons/GithubIcon.astro";
import LinkedinIcon from "../components/ui/icons/LinkedinIcon.astro";
import PageLayout from "../layouts/PageLayout.astro";
import { SITE } from "../lib/seo";
import portrait from "../assets/arun.png";

const links = [
  { label: "GitHub", href: SITE.github, Icon: GithubIcon },
  { label: "LinkedIn", href: SITE.linkedin, Icon: LinkedinIcon },
  { label: "Email", href: `mailto:${SITE.email}`, Icon: Mail },
];
---

<PageLayout
  title="About"
  description="Arun MV — AI engineer and product builder turning messy ideas into products people actually want to use. Driven by curiosity and a habit of learning by exploring."
  prose
>
  <div class="flex flex-col-reverse gap-6 sm:flex-row sm:items-center sm:justify-between">
    <h1 class="font-serif text-4xl font-semibold tracking-tight text-ink">
      I build AI products and thoughtful software.
    </h1>
    <Image
      src={portrait}
      alt="Arun MV"
      width={320}
      height={320}
      class="h-28 w-28 shrink-0 rounded-[var(--radius-lg)] border border-border object-cover shadow-sm sm:h-40 sm:w-40"
    />
  </div>

  <div class="prose mt-8">
    <p>Hey, I'm Arun.</p>
    <p>
      I'm an AI engineer and product builder who enjoys turning messy ideas into products people
      actually want to use.
    </p>
    <p>
      Over the last few years, I've worked across multiple languages, React, modern web stacks,
      and AI systems — building software that sits somewhere between engineering, product
      thinking, and experimentation. I enjoy the part where technology stops being a demo and
      starts becoming useful.
    </p>
    <p>
      Most of what I know, I learned by exploring — pulling things apart, building past the edge
      of what I understood, and following my curiosity wherever it pointed. That curiosity, and
      the confidence that I can figure things out, are what fuel me. It's how a question turns
      into a prototype, and a prototype turns into something real.
    </p>

    <p>This space is where I write about things I'm learning and building:</p>
    <ul>
      <li>AI products and applied intelligence</li>
      <li>Software engineering and developer tools</li>
      <li>Product design and systems thinking</li>
      <li>Experiments, failures, and lessons from shipping</li>
    </ul>

    <p>
      Outside work, I'm equally interested in the human side of things — football, long-term
      thinking, habits, stories, and the ideas that shape how we build and live.
    </p>
    <p>
      I don't write because I have all the answers. I write to think clearly, document what I
      discover, and leave useful trails for people building similar things.
    </p>
    <p>If something here resonates, stick around.</p>
  </div>

  <div class="mt-10 flex gap-4">
    {
      links.map(({ label, href, Icon }) => (
        <a
          href={href}
          aria-label={label}
          target={href.startsWith("mailto") ? undefined : "_blank"}
          rel="me noopener"
          class="inline-flex items-center gap-2 rounded-[var(--radius-md)] border border-border px-3 py-2 text-sm no-underline transition-colors hover:border-accent hover:text-accent"
        >
          <Icon size={16} stroke-width={1.5} /> {label}
        </a>
      ))
    }
  </div>
</PageLayout>
